# Copy the keys you need into Streamlit Cloud app secrets.
# Do not commit a real `.streamlit/secrets.toml` file.

# ── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = "your_anthropic_api_key_here"
LLM_FAST_MODEL = "claude-haiku-4-5-20251001"
LLM_REASONING_MODEL = "claude-sonnet-4-6"

OPENAI_API_KEY = "your_openai_api_key_here"
OPENAI_FAST_MODEL = "gpt-5.4-mini"
OPENAI_REASONING_MODEL = "gpt-5.4"

MF_API_BASE_URL = "https://mfdata.in/api/v1"
MF_HOLDINGS_TIMEOUT_SECONDS = 20

# ── Google OAuth (required for multi-user login) ──────────────────────────────
# Steps to obtain credentials:
#  1. Go to https://console.cloud.google.com → APIs & Services → Credentials
#  2. Create an OAuth 2.0 Client ID (Web application)
#  3. Add Authorised redirect URI:
#       https://<your-app-subdomain>.streamlit.app/oauth2callback
#  4. Copy the client_id and client_secret below.
#
# If this [auth] section is absent, the app runs in single-user mode (no login).

[auth]
redirect_uri = "https://<your-app-subdomain>.streamlit.app/oauth2callback"
cookie_secret = "replace-with-a-long-random-string"

[auth.google]
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
